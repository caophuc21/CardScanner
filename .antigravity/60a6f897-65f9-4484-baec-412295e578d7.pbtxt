    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useRef } from \"react\";\nimport { Camera, ScanLine, Users, ChevronLeft, Plus, Phone, Mail, Globe, Building2, MapPin, Briefcase, Save, Loader2, User } from \"lucide-react\";\nimport { Contact } from \"./types\";\n\ntype ViewState = \"contacts\" | \"scanner\" | \"editor\" | \"detail\";\n\nexport default function App() {\n  const [view, setView] = useState<ViewState>(\"contacts\");\n  const [contacts, setContacts] = useState<Contact[]>(() => {\n    try {\n      const saved = localStorage.getItem(\"contacts\");\n      return saved ? JSON.parse(saved) : [];\n    } catch {\n      return [];\n    }\n  });\n  const [selectedContact, setSelectedContact] = useState<Contact | null>(null);\n  \n  // For scanning\n  const [isProcessing, setIsProcessing] = useState(false);\n  const [previewImage, setPreviewImage] = useState<string | null>(null);\n  const [editForm, setEditForm] = useState<Partial<Contact>>({});\n  const fileInputRef = useRef<HTMLInputElement>(null);\n\n  const saveContacts = (newContacts: Contact[]) => {\n    setContacts(newContacts);\n    localStorage.setItem(\"contacts\", JSON.stringify(newContacts));\n  };\n\n  const handleCapture = async (e: React.ChangeEvent<HTMLInputElement>) => {\n    const file = e.target.files?.[0];\n    if (!file) return;\n\n    // Show preview\n    const reader = new FileReader();\n    reader.onload = async (event) => {\n      const base64 = event.target?.result as string;\n      setPreviewImage(base64);\n      setView(\"scanner\");\n      setIsProcessing(true);\n\n      try {\n        const res = await fetch(\"/api/extract\", {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify({ image: base64 }),\n        });\n\n        if (!res.ok) throw new Error(\"Failed to extract details\");\n        \n        const { data } = await res.json();\n        setEditForm(data);\n        setView(\"editor\");\n      } catch (err) {\n        console.error(err);\n        alert(\"Could not process the card. Please try again.\");\n        setView(\"contacts\");\n      } finally {\n        setIsProcessing(false);\n        setPreviewImage(null);\n      }\n    };\n    reader.readAsDataURL(file);\n  };\n\n  const saveNewContact = () => {\n    const newContact: Contact = {\n      id: crypto.randomUUID(),\n      name: editForm.name || \"\",\n      jobTitle: editForm.jobTitle || \"\",\n      company: editForm.company || \"\",\n      phone: editForm.phone || \"\",\n      email: editForm.email || \"\",\n      website: editForm.website || \"\",\n      address: editForm.address || \"\",\n      createdAt: Date.now(),\n    };\n    saveContacts([...contacts, newContact]);\n    setView(\"contacts\");\n  };\n\n  return (\n    <div className=\"min-h-screen bg-gray-50 flex flex-col font-sans text-gray-900 max-w-md mx-auto sm:border-x sm:shadow-lg relative pb-20\">\n      \n      {/* HEADER */}\n      <header className=\"bg-white border-b px-4 py-4 flex items-center justify-between sticky top-0 z-10\">\n        {(view === \"editor\" || view === \"detail\") ? (\n          <button \n            onClick={() => setView(\"contacts\")} \n            className=\"p-2 -ml-2 rounded-full hover:bg-gray-100 text-gray-600 transition\"\n          >\n            <ChevronLeft size={24} />\n          </button>\n        ) : (\n          <div className=\"w-10\"></div>\n        )}\n        \n        <h1 className=\"text-lg font-semibold tracking-tight\">\n          {view === \"contacts\" && \"My Cards\"}\n          {view === \"scanner\" && \"Scanning...\"}\n          {view === \"editor\" && \"Review Details\"}\n          {view === \"detail\" && selectedContact?.name}\n        </h1>\n        \n        <div className=\"w-10 flex justify-end\"></div>\n      </header>\n\n      {/* MAIN CONTENT */}\n      <main className=\"flex-1 overflow-y-auto\">\n        \n        {/* CONTACTS LIST */}\n        {view === \"contacts\" && (\n          <div className=\"p-4 space-y-3\">\n            {contacts.length === 0 ? (\n              <div className=\"flex flex-col items-center justify-center h-[60vh] text-center px-6\">\n                <div className=\"w-16 h-16 bg-blue-50 text-blue-500 rounded-full flex items-center justify-center mb-4\">\n                  <ScanLine size={32} />\n                </div>\n                <h2 className=\"text-xl font-medium text-gray-800 mb-2\">No cards yet</h2>\n                <p className=\"text-gray-500\">Tap the scan button below to digitize your first business card.</p>\n              </div>\n            ) : (\n              contacts.sort((a,b) => b.createdAt - a.createdAt).map(contact => (\n                <button\n                  key={contact.id}\n                  onClick={() => { setSelectedContact(contact); setView(\"detail\"); }}\n                  className=\"w-full bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex items-center gap-4 active:scale-[0.98] transition-transform text-left\"\n                >\n                  <div className=\"w-12 h-12 bg-gradient-to-br from-gray-100 to-gray-200 rounded-full flex items-center justify-center text-gray-500 font-medium text-lg shrink-0\">\n                    {contact.name.charAt(0).toUpperCase() || <User size={20} />}\n                  </div>\n                  <div className=\"flex-1 min-w-0\">\n                    <h3 className=\"font-semibold text-gray-900 truncate\">{contact.name || \"Unknown\"}</h3>\n                    <p className=\"text-sm text-gray-500 truncate\">\n                      {contact.jobTitle}{contact.jobTitle && contact.company ? \" at \" : \"\"}{contact.company}\n                    </p>\n                  </div>\n                </button>\n              ))\n            )}\n          </div>\n        )}\n\n        {/* SCANNER OVERLAY (Processing State) */}\n        {view === \"scanner\" && (\n          <div className=\"flex flex-col items-center justify-center h-full p-6 text-center\">\n            {previewImage && (\n              <div className=\"relative w-full aspect-[4/3] rounded-2xl overflow-hidden shadow-lg mb-8 border-4 border-white\">\n                <img src={previewImage} alt=\"Card Preview\" className=\"w-full h-full object-cover filter brightness-75\" />\n                <div className=\"absolute inset-0 flex flex-col items-center justify-center\">\n                   <Loader2 size={40} className=\"text-white animate-spin mb-4 drop-shadow-md\" />\n                   <p className=\"text-white font-medium drop-shadow-md\">Extracting text with AI...</p>\n                </div>\n              </div>\n            )}\n          </div>\n        )}\n\n        {/* EDITOR */}\n        {view === \"editor\" && (\n          <div className=\"p-4 space-y-6\">\n            <div className=\"bg-white p-5 rounded-2xl shadow-sm border border-gray-100 space-y-4\">\n              <FormField \n                icon={<User size={18} />} \n                label=\"Full Name\" \n                value={editForm.name} \n                onChange={(val) => setEditForm({...editForm, name: val})} \n              />\n              <FormField \n                icon={<Briefcase size={18} />} \n                label=\"Job Title\" \n                value={editForm.jobTitle} \n                onChange={(val) => setEditForm({...editForm, jobTitle: val})} \n              />\n              <FormField \n                icon={<Building2 size={18} />} \n                label=\"Company\" \n                value={editForm.company} \n                onChange={(val) => setEditForm({...editForm, company: val})} \n              />\n              <FormField \n                icon={<Phone size={18} />} \n                label=\"Phone\" \n                value={editForm.phone} \n                onChange={(val) => setEditForm({...editForm, phone: val})} \n              />\n              <FormField \n                icon={<Mail size={18} />} \n                label=\"Email\" \n                value={editForm.email} \n                onChange={(val) => setEditForm({...editForm, email: val})} \n                type=\"email\"\n              />\n              <FormField \n                icon={<Globe size={18} />} \n                label=\"Website\" \n                value={editForm.website} \n                onChange={(val) => setEditForm({...editForm, website: val})} \n                type=\"url\"\n              />\n              <FormField \n                icon={<MapPin size={18} />} \n                label=\"Address\" \n                value={editForm.address} \n                onChange={(val) => setEditForm({...editForm, address: val})} \n              />\n            </div>\n            \n            <button \n              onClick={saveNewContact}\n              className=\"w-full bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white font-medium py-4 rounded-2xl flex items-center justify-center gap-2 transition\"\n            >\n              <Save size={20} />\n              Save Contact\n            </button>\n          </div>\n        )}\n\n        {/* CONTACT DETAIL */}\n        {view === \"detail\" && selectedContact && (\n          <div className=\"p-4\">\n            <div className=\"bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col items-center text-center mb-6\">\n              <div className=\"w-20 h-20 bg-gradient-to-br from-blue-100 to-blue-200 rounded-full flex items-center justify-center text-blue-600 font-bold text-3xl mb-4\">\n                {selectedContact.name.charAt(0).toUpperCase() || <User size={32} />}\n              </div>\n              <h2 className=\"text-2xl font-bold text-gray-900\">{selectedContact.name || \"No Name\"}</h2>\n              <p className=\"text-gray-500 mt-1\">{selectedContact.jobTitle}</p>\n              <p className=\"font-medium text-gray-700\">{selectedContact.company}</p>\n            </div>\n\n            <div className=\"space-y-3\">\n              <DetailRow icon={<Phone />} value={selectedContact.phone} type=\"tel\" />\n              <DetailRow icon={<Mail />} value={selectedContact.email} type=\"mailto\" />\n              <DetailRow icon={<Globe />} value={selectedContact.website} type=\"url\" />\n              <DetailRow icon={<MapPin />} value={selectedContact.address} />\n            </div>\n\n            <button \n              onClick={() => {\n                const confirm = window.confirm(\"Delete this contact?\");\n                if (confirm) {\n                  saveContacts(contacts.filter(c => c.id !== selectedContact.id));\n                  setView(\"contacts\");\n                }\n              }}\n              className=\"w-full text-red-500 font-medium py-4 mt-8 bg-red-50 rounded-2xl\"\n            >\n              Delete Contact\n            </button>\n          </div>\n        )}\n      </main>\n\n      {/* HIDDEN FILE INPUT FOR NATIVE CAMERA */}\n      <input \n        type=\"file\" \n        accept=\"image/*\" \n        capture=\"environment\"\n        className=\"hidden\"\n        ref={fileInputRef}\n        onChange={handleCapture}\n      />\n\n      {/* BOTTOM NAV */}\n      {view === \"contacts\" && (\n        <div className=\"fixed bottom-0 left-0 right-0 bg-white border-t px-6 pb-8 pt-4 flex justify-between items-center max-w-md mx-auto sm:border-x\">\n          <button \n            className=\"flex flex-col items-center text-blue-600 p-2\"\n          >\n            <Users size={24} className=\"mb-1\" />\n            <span className=\"text-xs font-medium\">Contacts</span>\n          </button>\n          \n          <button \n            onClick={() => fileInputRef.current?.click()}\n            className=\"flex items-center justify-center bg-blue-600 text-white w-14 h-14 rounded-full shadow-lg shadow-blue-200 hover:bg-blue-700 active:scale-95 transition-all -mt-8\"\n          >\n            <ScanLine size={24} />\n          </button>\n          \n          <button \n            onClick={() => {\n              // Quick manual add\n              setEditForm({});\n              setView(\"editor\");\n            }}\n            className=\"flex flex-col items-center text-gray-400 hover:text-gray-600 p-2 transition\"\n          >\n            <Plus size={24} className=\"mb-1\" />\n            <span className=\"text-xs font-medium\">Manual</span>\n          </button>\n        </div>\n      )}\n    </div>\n  );\n}\n\nfunction FormField({ icon, label, value, onChange, type = \"text\" }: { \n  icon: React.ReactNode, \n  label: string, \n  value?: string, \n  onChange: (val: string) => void,\n  type?: string\n}) {\n  return (\n    <div>\n      <label className=\"flex items-center gap-2 text-sm font-medium text-gray-500 mb-1.5 ml-1\">\n        <span className=\"text-gray-400\">{icon}</span>\n        {label}\n      </label>\n      <input\n        type={type}\n        value={value || \"\"}\n        onChange={(e) => onChange(e.target.value)}\n        className=\"w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition\"\n        placeholder={`Enter ${label.toLowerCase()}`}\n      />\n    </div>\n  );\n}\n\nfunction DetailRow({ icon, value, type }: { icon: React.ReactNode, value?: string, type?: \"tel\" | \"mailto\" | \"url\" }) {\n  if (!value) return null;\n  \n  const content = (\n    <div className=\"flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-gray-100\">\n      <div className=\"text-blue-500 bg-blue-50 p-2 rounded-xl\">\n        {icon}\n      </div>\n      <span className=\"font-medium text-gray-700 flex-1 break-all\">{value}</span>\n    </div>\n  );\n\n  if (type === \"tel\") return <a href={`tel:${value}`} className=\"block\">{content}</a>;\n  if (type === \"mailto\") return <a href={`mailto:${value}`} className=\"block\">{content}</a>;\n  if (type === \"url\") {\n    const href = value.startsWith(\'http\') ? value : `https://${value}`;\n    return <a href={href} target=\"_blank\" rel=\"noopener noreferrer\" className=\"block\">{content}</a>;\n  }\n  \n  return content;\n}\n"
